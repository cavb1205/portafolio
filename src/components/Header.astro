---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "../i18n/ui";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section
  class="container relative mx-auto grid place-items-center py-8 overflow-hidden"
>
  <!-- Glow decorativo de fondo -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-72 w-72 rounded-full bg-primary/20 blur-3xl"
  >
  </div>

  <div class="relative grid grid-cols-1 gap-8 w-full max-w-4xl">
    <!-- Hero -->
    <div class="flex flex-col gap-5 justify-center items-center text-center">
      <div class="p-1 bg-dark-lighter rounded-full shadow-md">
        <img
          src="/images/foto-camilo-varon.webp"
          alt={t("photo.alt")}
          width="160"
          height="160"
          fetchpriority="high"
          class="w-40 h-40 rounded-full object-cover border-2 border-dark-darker shadow-inner hover:scale-[1.02] transition-transform duration-300"
        />
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-primary text-4xl md:text-5xl font-bold">
          Camilo Andrés Varón
        </h1>
        <p class="text-secondary text-sm md:text-base">
          {t("hero.role")}
        </p>
      </div>

      <!-- Propuesta de valor -->
      <p class="text-gray-200 text-lg md:text-xl max-w-2xl text-balance">
        {t("hero.build")}{" "}
        <span class="text-accent font-semibold">{t("hero.stores")}</span>{" "}
        {t("hero.and")}{" "}
        <span class="text-accent font-semibold">{t("hero.apps")}</span>{" "}
        {t("hero.with")}{" "}
        <span class="text-primary font-semibold">React</span>,{" "}
        <span class="text-primary font-semibold">Next.js</span>{" "}
        {t("hero.and")}{" "}
        <span class="text-primary font-semibold">Astro</span>.
      </p>
      <p class="text-gray-400 max-w-xl">
        {t("hero.subtitle")}
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row gap-3 w-full max-w-md justify-center mt-2"
      >
        <a
          href="#contacto"
          class="flex-1 inline-flex items-center justify-center gap-2 bg-primary text-dark-darker font-semibold py-3 px-6 rounded-md hover:bg-opacity-90 transition-all hover:-translate-y-1 shadow-lg shadow-primary/20"
        >
          <Icon name="ri:chat-smile-3-line" class="text-lg" aria-hidden="true" />
          {t("hero.ctaPrimary")}
        </a>
        <a
          href="#proyectos"
          class="flex-1 inline-flex items-center justify-center gap-2 border border-primary/50 text-primary font-semibold py-3 px-6 rounded-md hover:bg-primary/10 transition-all hover:-translate-y-1"
        >
          <Icon name="ri:folder-chart-line" class="text-lg" aria-hidden="true" />
          {t("hero.ctaSecondary")}
        </a>
      </div>

      <!-- Redes sociales -->
      <div class="flex items-center gap-3 mt-1">
        <a
          href="https://www.linkedin.com/in/camilovaron/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("hero.linkedin")}
          class="flex items-center justify-center w-10 h-10 rounded-full bg-dark-lighter text-gray-300 hover:text-primary transition-colors"
        >
          <Icon name="ri:linkedin-box-fill" class="text-xl" aria-hidden="true" />
        </a>
        <a
          href="https://github.com/cavb1205"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("hero.github")}
          class="flex items-center justify-center w-10 h-10 rounded-full bg-dark-lighter text-gray-300 hover:text-primary transition-colors"
        >
          <Icon name="ri:github-fill" class="text-xl" aria-hidden="true" />
        </a>
      </div>
    </div>

    <!-- Sobre mí -->
    <div class="flex flex-col gap-4 items-center" data-reveal>
      <h2 class="text-primary text-2xl font-bold text-center">{t("about.title")}</h2>
      <p class="text-gray-300 text-center max-w-2xl">
        {t("about.body")}
      </p>
    </div>
  </div>
</section>
