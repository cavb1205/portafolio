---
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro'
import Footer from "../components/Footer.astro";
import { getLang } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
}

const lang = getLang(Astro.currentLocale);
const isEn = lang === "en";

const {
  title,
  description = "Portafolio de Camilo Varón, desarrollador frontend especializado en React, Next.js y Astro. Con base en Chile.",
} = Astro.props;

const SITE_URL = "https://www.camilovaron.dev";
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = new URL("/images/foto-camilo-varon.webp", SITE_URL).href;
const ogLocale = isEn ? "en_US" : "es_ES";
const skipLabel = isEn ? "Skip to content" : "Saltar al contenido";

const alternates = [
  { hreflang: "es", href: `${SITE_URL}/` },
  { hreflang: "en", href: `${SITE_URL}/en/` },
  { hreflang: "x-default", href: `${SITE_URL}/` },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Camilo Andrés Varón",
  url: SITE_URL,
  image: ogImage,
  jobTitle: isEn ? "Frontend Developer" : "Desarrollador Frontend",
  email: "ing.camilo.varon@gmail.com",
  nationality: "Colombiana",
  homeLocation: { "@type": "Place", name: "Chile" },
  knowsAbout: ["React", "Next.js", "Astro", "JavaScript", "TailwindCSS"],
  sameAs: [
    "https://www.linkedin.com/in/camilovaron/",
    "https://github.com/cavb1205",
  ],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <script is:inline>
      // Habilita las animaciones de scroll solo si hay JS (evita contenido oculto sin JS).
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta name="theme-color" content="#0F172A" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Camilo Varón" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@cavb1205" />
    <meta name="twitter:creator" content="@cavb1205" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class="bg-dark min-h-screen">
    <a
      href="#inicio"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-dark-darker focus:font-semibold"
    >
      {skipLabel}
    </a>
    <slot />
    <Footer />
    <Analytics />

    <script>
      const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
      const reveal = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              reveal.unobserve(entry.target);
            }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
      );
      revealEls.forEach((el) => reveal.observe(el));
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: "Inter", system-ui, sans-serif;
  }

  body {
    background: theme("colors.dark.DEFAULT");
  }

  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
</style>
